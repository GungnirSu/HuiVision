<view class="page">
  <view class="header">
    <view class="back-btn" bindtap="backToHome">返回</view>
    <view class="title">导航</view>
  </view>

  <view class="search-panel {{searchFocused ? 'expanded' : ''}}">
    <view class="search-bar">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="输入目的地"
        value="{{destination}}"
        bindinput="onInputChange"
        bindfocus="onSearchFocus"
        bindblur="onSearchBlur"
        confirm-type="search"
        bindconfirm="startNavigation"
      />
      <view class="search-btn" bindtap="startNavigation">开始</view>
    </view>

    <view class="location-row">
      <view class="location-btn" bindtap="openLocation">定位</view>
      <text class="location-text">{{currentLocationText}}</text>
    </view>

    <view wx:if="{{isNavigating}}" class="connection-row">
      <text class="connection-tag">状态</text>
      <text class="connection-text">{{connectionHint}}</text>
    </view>

    <view wx:if="{{searchFocused}}" class="quick-grid">
      <block wx:for="{{quickOptions}}" wx:key="id">
        <view class="quick-item" data-label="{{item.label}}" bindtap="chooseQuickOption">
          <view class="quick-icon">{{item.icon}}</view>
          <text class="quick-label">{{item.label}}</text>
        </view>
      </block>
    </view>
  </view>

  <view class="main-intro-card">
    <view class="main-step-label">当前导航提示</view>
    <view class="main-step-text">{{currentStepText}}</view>
    <view class="main-state-line">
      <text class="main-state-badge {{isNavigating ? 'active' : ''}}">{{navigationState}}</text>
      <text class="main-distance">距终点：{{distanceText}}</text>
    </view>
  </view>

  <view class="map-card">
    <map
      id="navMap"
      class="nav-map"
      longitude="{{mapCenterLng}}"
      latitude="{{mapCenterLat}}"
      scale="{{scale}}"
      min-scale="{{16}}"
      max-scale="{{18}}"
      markers="{{markers}}"
      polyline="{{polyline}}"
      show-location="{{true}}"
      enable-zoom="{{true}}"
      enable-scroll="{{true}}"
      enable-rotate="{{false}}"
      enable-3D="{{false}}"
      enable-overlooking="{{false}}"
      enable-satellite="{{false}}"
      enable-traffic="{{false}}"
      enable-poi="{{true}}"
      skew="{{0}}"
      show-compass="{{true}}"
      show-scale="{{true}}"
      bindregionchange="onMapRegionChange"
    />
    <view class="map-controls">
      <view class="map-control-btn" bindtap="openLocation">定位到我</view>
      <view class="map-control-btn secondary" bindtap="initMapCenter">重新居中</view>
    </view>
  </view>

  <view class="nav-info-card">
    <view class="nav-info-row">
      <text class="nav-info-label">路线长度</text>
      <text class="nav-info-value">{{routeSummaryText}}</text>
    </view>
    <view class="nav-info-row">
      <text class="nav-info-label">当前步骤</text>
      <text class="nav-info-value">{{currentStepText}}</text>
    </view>
    <view wx:if="{{arrivedText}}" class="arrived-badge">{{arrivedText}}</view>

    <view wx:if="{{isNavigating}}" class="stop-btn" bindtap="stopNavigation">
      停止导航
    </view>
  </view>
</view>