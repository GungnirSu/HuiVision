.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0b1d3a 0%, #f4f7fb 45%, #f4f7fb 100%);
  padding: 32rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #fff;
  margin-bottom: 32rpx;
}

.back-btn {
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
}

.search-panel,
.main-intro-card,
.map-card,
.nav-info-card,
.coexist-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.08);
}

.search-panel.expanded {
  padding-bottom: 12rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  border: 2rpx solid #dbe4f0;
  border-radius: 20rpx;
  padding: 16rpx;
}

.search-icon {
  font-size: 32rpx;
}

.search-input {
  flex: 1;
  min-height: 48rpx;
}

.search-btn {
  background: #1677ff;
  color: #fff;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
}

.location-row,
.connection-row,
.main-state-line {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 18rpx;
  flex-wrap: wrap;
}

.location-btn {
  background: #eef2f7;
  color: #334155;
  padding: 12rpx 18rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
}

.location-text,
.connection-text {
  color: #667085;
  line-height: 1.6;
}

.connection-tag {
  display: inline-block;
  background: #e8f3ff;
  color: #1677ff;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-top: 20rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 18rpx 8rpx;
  border-radius: 18rpx;
  background: #f6f9ff;
}

.quick-icon {
  font-size: 36rpx;
}

.quick-label {
  font-size: 24rpx;
}

.main-intro-card {
  border: 1rpx solid #dbe4f0;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
}

.main-step-label {
  font-size: 24rpx;
  color: #1677ff;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.main-step-text {
  font-size: 34rpx;
  line-height: 1.5;
  font-weight: 700;
  color: #0f172a;
}

.main-state-line {
  justify-content: space-between;
}

.main-state-badge {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #edf2f7;
  color: #334155;
  font-size: 24rpx;
  font-weight: 600;
}

.main-state-badge.active {
  background: #e8f3ff;
  color: #1677ff;
}

.main-distance {
  color: #475467;
  font-size: 24rpx;
}

.map-card {
  padding: 16rpx;
}

.nav-map {
  width: 100%;
  height: 520rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.map-controls {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.map-control-btn,
.stop-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 600;
}

.map-control-btn {
  background: #1677ff;
  color: #fff;
}

.map-control-btn.secondary {
  background: #eef2f7;
  color: #334155;
}

.nav-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #edf1f5;
}

.nav-info-row:last-child {
  border-bottom: none;
}

.nav-info-label {
  color: #334155;
  font-weight: 600;
  flex-shrink: 0;
}

.nav-info-value {
  color: #667085;
  text-align: right;
  line-height: 1.6;
}

.arrived-badge {
  margin-top: 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 14rpx;
  background: #e8fff1;
  color: #067647;
  text-align: center;
  font-weight: 600;
}

.stop-btn {
  margin-top: 20rpx;
  background: #ff4d4f;
  color: #fff;
}

.coexist-title {
  display: block;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.coexist-desc {
  display: block;
  color: #667085;
  line-height: 1.6;
}
