/* 全局重置 */
page {
  background-color: #f5f5f5;
  font-size: 32rpx;
  color: #333;
  height: 100vh;
  overflow: hidden;
}

/* 主容器 */
.container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding: 20rpx;
  position: relative;
  z-index: 1;
  background-color: transparent;
}

/* 1. 顶部导航栏 */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

/* 左侧模式切换 */
.tab-group {
  display: flex;
  width: 300rpx;
  height: 70rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 35rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.tab-item {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  font-weight: 600;
  color: #666;
  font-size: 30rpx;
  transition: all 0.3s ease;
}

.tab-active {
  background-color: #fff;
  color: #007aff;
  font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(0,122,255,0.2);
}

/* 右侧功能按钮 */
.top-right {
  display: flex;
  align-items: center;
}

.top-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 36rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  transition: transform 0.2s ease;
}

.top-btn:active {
  transform: scale(0.95);
}

/* 实时分析开关 */
.switch-wrap {
  position: absolute;
  top: 120rpx;
  right: 20rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  z-index: 10;
  background-color: rgba(255, 255, 255, 0.9);
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.switch-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.realtime-switch {
  transform: scale(1.2);
}

/* 2. 功能按钮区（底部上方） */
.action-buttons {
  position: absolute;
  bottom: 200rpx;
  left: 20rpx;
  right: 20rpx;
  display: flex;
  gap: 15rpx;
  z-index: 5;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  background-color: rgba(255, 255, 255, 0.9);
  color: #333;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  transition: all 0.3s ease;
}

.quick-btn {
  background-color: #ffcc00;
  color: #333;
  font-weight: 700;
  box-shadow: 0 4rpx 15rpx rgba(255,204,0,0.3);
  flex: 2;
}

.action-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 3. 对话播报区（中部，半透明） */
.broadcast-area {
  position: absolute;
  top: 200rpx;
  left: 20rpx;
  right: 20rpx;
  height: 150rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  overflow-y: auto;
  backdrop-filter: blur(5rpx);
  z-index: 4;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

/* 4. 底部交互区 */
.input-bar {
  position: absolute;
  bottom: 20rpx;
  left: 20rpx;
  right: 20rpx;
  z-index: 5;
}

.input-container {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 60rpx;
  padding: 15rpx 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.input-middle {
  flex: 1;
}

.input-field {
  width: 100%;
  height: 60rpx;
  font-size: 30rpx;
  color: #333;
  padding: 0 10rpx;
}

.input-right {
  margin-left: 15rpx;
}

.voice-btn {
  width: 60rpx;
  height: 60rpx;
  background-color: #007aff;
  color: #fff;
  border-radius: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,122,255,0.3);
}

.input-footer {
  text-align: center;
  margin-top: 10rpx;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}