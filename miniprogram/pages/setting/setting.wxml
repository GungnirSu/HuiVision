<!-- 设置页面 -->
<view class="setting-container">
  <!-- 顶部导航栏 -->
  <view class="setting-header">
    <view class="header-left" bindtap="navigateBack">
      <text class="back-icon">←</text>
      <text class="header-title">设置</text>
    </view>
  </view>

  <view class="setting-section">
    <view class="section-title">导航参数</view>

    <view class="setting-item">
      <view class="setting-info">
        <text class="setting-title">更新频率</text>
        <text class="setting-desc">{{navUpdateIntervalSec}} 秒 / 次</text>
      </view>
      <slider min="0" max="2" step="1" value="1" bindchange="onIntervalChange" />
    </view>

    <view class="setting-item">
      <view class="setting-info">
        <text class="setting-title">偏航灵敏度</text>
        <text class="setting-desc">{{navOffRouteThresholdM}} 米</text>
      </view>
      <slider min="0" max="2" step="1" value="1" bindchange="onOffRouteChange" />
    </view>

    <view class="setting-item">
      <view class="setting-info">
        <text class="setting-title">到达判定距离</text>
        <text class="setting-desc">{{navArriveThresholdM}} 米</text>
      </view>
      <slider min="0" max="2" step="1" value="1" bindchange="onArriveChange" />
    </view>

    <view class="setting-item input-item">
      <view class="setting-info">
        <text class="setting-title">默认城市</text>
        <text class="setting-desc">用于目的地搜索和地理编码兜底</text>
      </view>
      <input class="city-input" value="{{navDefaultCity}}" placeholder="请输入默认城市" bindinput="onCityInput" />
    </view>

    <view class="setting-actions">
      <view class="save-btn" bindtap="saveNavSettings">保存导航设置</view>
      <view class="reset-btn" bindtap="resetNavSettings">恢复默认</view>
    </view>
  </view>

  <!-- 设置列表 -->
  <view class="setting-list">
    <!-- 1. 问答对话播报设置 -->
    <view class="setting-item" bindtap="openDialogSetting">
      <view class="setting-info">
        <text class="setting-title">📢 问答对话播报设置</text>
        <text class="setting-desc">标准 / 简洁 / 仅文字</text>
      </view>
      <view class="setting-arrow">></view>
    </view>

    <!-- 2. 出行模式设置 -->
    <view class="setting-item" bindtap="openTravelSetting">
      <view class="setting-info">
        <text class="setting-title">🧭 出行模式设置</text>
        <text class="setting-desc">AI出行 / 仅障碍物 / 仅路况</text>
      </view>
      <view class="setting-arrow">></view>
    </view>

    <!-- 3. 会视模式设置 -->
    <view class="setting-item" bindtap="openVisionSetting">
      <view class="setting-info">
        <text class="setting-title">👁️ 会视模式设置</text>
        <text class="setting-desc">详细讲解 / 快速分析 / 阅读文字</text>
      </view>
      <view class="setting-arrow">></view>
    </view>

    <!-- 4. 导航设置（仅出行） -->
    <view class="setting-item" bindtap="openNavigationSetting">
      <view class="setting-info">
        <text class="setting-title">🗺️ 导航设置</text>
        <text class="setting-desc">第三方地图选择 / 路线偏好</text>
      </view>
      <view class="setting-arrow">></view>
    </view>

    <!-- 5. 音频设置 -->
    <view class="setting-item" bindtap="openAudioSetting">
      <view class="setting-info">
        <text class="setting-title">🔊 音频设置</text>
        <text class="setting-desc">音量 / 语速 / 音色</text>
      </view>
      <view class="setting-arrow">></view>
    </view>

    <!-- 6. 恢复默认设置 -->
    <view class="setting-item reset-item" bindtap="resetSettings">
      <view class="setting-info">
        <text class="setting-title reset-title">♻️ 恢复默认设置</text>
      </view>
    </view>
  </view>
</view>