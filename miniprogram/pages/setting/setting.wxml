<!-- 设置页面 -->
<view class="setting-container">
  <!-- 顶部导航栏 -->
  <view class="setting-header">
    <view class="header-left" bindtap="navigateBack">
      <text class="back-icon">←</text>
      <text class="header-title">设置</text>
    </view>
  </view>

  <!-- 设置列表 -->
  <view class="setting-list">
    <!-- 1. 问答对话播报设置 -->
    <view class="setting-item" bindtap="openDialogSetting">
      <view class="setting-info">
        <text class="setting-title">📢 问答对话播报设置</text>
        <text class="setting-desc">标准 / 简洁 / 仅文字</text>
      </view>
      <view class="setting-arrow">></view>
    </view>

    <!-- 2. 出行模式设置 -->
    <view class="setting-item" bindtap="openTravelSetting">
      <view class="setting-info">
        <text class="setting-title">🧭 出行模式设置</text>
        <text class="setting-desc">AI出行 / 仅障碍物 / 仅路况</text>
      </view>
      <view class="setting-arrow">></view>
    </view>

    <!-- 3. 会视模式设置 -->
    <view class="setting-item" bindtap="openVisionSetting">
      <view class="setting-info">
        <text class="setting-title">👁️ 会视模式设置</text>
        <text class="setting-desc">详细讲解 / 快速分析 / 阅读文字</text>
      </view>
      <view class="setting-arrow">></view>
    </view>

    <!-- 4. 导航设置（仅出行） -->
    <view class="setting-item" bindtap="openNavigationSetting">
      <view class="setting-info">
        <text class="setting-title">🗺️ 导航设置</text>
        <text class="setting-desc">第三方地图选择 / 路线偏好</text>
      </view>
      <view class="setting-arrow">></view>
    </view>

    <!-- 5. 音频设置 -->
    <view class="setting-item" bindtap="openAudioSetting">
      <view class="setting-info">
        <text class="setting-title">🔊 音频设置</text>
        <text class="setting-desc">音量 / 语速 / 音色</text>
      </view>
      <view class="setting-arrow">></view>
    </view>

    <!-- 6. 恢复默认设置 -->
    <view class="setting-item reset-item" bindtap="resetSettings">
      <view class="setting-info">
        <text class="setting-title reset-title">♻️ 恢复默认设置</text>
      </view>
    </view>
  </view>
</view>