.setting-container {
  min-height: 100vh;
  background: #f4f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.setting-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.back-icon {
  font-size: 32rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
}

.setting-section,
.setting-list {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.setting-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf1f5;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-info {
  margin-bottom: 12rpx;
}

.setting-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
}

.setting-desc {
  display: block;
  font-size: 24rpx;
  color: #667085;
  margin-top: 8rpx;
}

.input-item .city-input {
  margin-top: 12rpx;
  padding: 18rpx;
  border: 1rpx solid #dbe4f0;
  border-radius: 16rpx;
  background: #f9fbfd;
}

.setting-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.save-btn,
.reset-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 600;
}

.save-btn {
  background: #1677ff;
  color: #fff;
}

.reset-btn {
  background: #eef2f7;
  color: #334155;
}

.reset-item {
  text-align: center;
}

.reset-title {
  color: #d92d20;
}

.setting-arrow {
  color: #98a2b3;
  font-size: 28rpx;
}
