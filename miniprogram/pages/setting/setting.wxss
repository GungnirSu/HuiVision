/* 设置页面样式 */
.page {
  background-color: #f5f5f5;
  font-size: 32rpx;
  color: #333;
  height: 100vh;
  overflow: hidden;
}

.setting-container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 顶部导航栏 */
.setting-header {
  height: 80rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.back-icon {
  font-size: 40rpx;
  color: #333;
  font-weight: bold;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

/* 设置列表 */
.setting-list {
  flex: 1;
  padding: 20rpx 0;
  overflow-y: auto;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #fff;
  padding: 30rpx 20rpx;
  margin-bottom: 2rpx;
  transition: background-color 0.2s ease;
}

.setting-item:active {
  background-color: #f5f5f5;
}

.setting-info {
  flex: 1;
}

.setting-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.setting-desc {
  font-size: 26rpx;
  color: #999;
  display: block;
}

.setting-arrow {
  font-size: 32rpx;
  color: #999;
  margin-left: 20rpx;
}

/* 恢复默认设置 */
.reset-item {
  margin-top: 40rpx;
}

.reset-title {
  color: #ff3b30;
  font-weight: 700;
}
